}

@article{kellenTestingFoundationsSignal2021,
  title = {Testing the Foundations of Signal Detection Theory in Recognition Memory.},
  author = {Kellen, David and Winiger, Samuel and Dunn, John C. and Singmann, Henrik},
  year = 2021,
